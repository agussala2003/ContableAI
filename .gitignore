# ──────────────────────────────────────────────────────────────────────────────
#  .NET / C# backend
# ──────────────────────────────────────────────────────────────────────────────
backend/**/bin/
backend/**/obj/
backend/**/TestResults/
backend/**/*.user
backend/**/*.suo
backend/.vs/
backend/src/ContableAI.API/appsettings.Development.json

# Migraciones despliegue (mantener las fuentes, no los artefactos de runtime)
backend/**/*.db
backend/**/*.db-shm
backend/**/*.db-wal

# Certificados AFIP — NUNCA subir al repositorio
backend/certs/*.p12
backend/certs/*.pfx
backend/certs/*.pem
backend/certs/*.key

# Logs generados por Serilog
backend/logs/
!backend/logs/.gitkeep

